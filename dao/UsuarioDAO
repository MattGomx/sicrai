package dao;

import java.sql.PreparedStatement;
import java.sql.SQLException;
import java.sql.ResultSet;
import java.sql.Connection;
import javax.swing.JOptionPane;
import model.Usuario;
import model.Conexao;

public class UsuarioDAO {

    public int insertUsuario(Usuario usuario) {
        int id = 0;

        try {
            Conexao c = new Conexao();
            try (Connection con = c.obterConexao()) {
                String SQL = "INSERT INTO sicrai.usuario (nome, email, senha, pontos) VALUES ( ?, ?, ?, ? ) RETURNING id";
                PreparedStatement p = con.prepareStatement(SQL);
                p.setString(1, usuario.getNome());
                p.setString(2, usuario.getEmail());
                p.setString(3, usuario.getSenha());
                p.setInt(4, 0);
                ResultSet r = p.executeQuery();
                if (r.next()) {
                    id = r.getInt("id");
                    JOptionPane.showMessageDialog(null, "Id gerado: " + id);
                    return id;
                }
            }
        } catch (SQLException ex) {
            JOptionPane.showMessageDialog(null, ex.getMessage(), "Erro", JOptionPane.OK_OPTION);
        }
    }